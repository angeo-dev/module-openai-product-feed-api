{
    "name": "angeo/module-openai-product-feed-api",
    "description": "Magento 2 REST API for the OpenAI Agentic Commerce Protocol (ACP). Implements the ACP feed API surface: feeds, paginated products with configurable variants, and SalesRule-sourced promotions. Bearer-token authenticated, DB-persisted feeds, PATCH-as-POST bridge for Magento compatibility.",
    "type": "magento2-module",
    "version": "2.0.1",
    "license": "MIT",
    "authors": [
        {
            "name": "Ievgenii Gryshkun",
            "email": "info@angeo.dev",
            "homepage": "https://angeo.dev"
        }
    ],
    "keywords": [
        "magento2",
        "openai",
        "chatgpt",
        "agentic commerce",
        "acp",
        "product feed api",
        "promotions api",
        "aeo",
        "angeo"
    ],
    "homepage": "https://angeo.dev",
    "support": {
        "email": "support@angeo.dev"
    },
    "require": {
        "php": ">=8.1",
        "magento/framework": "*",
        "magento/module-catalog": "*",
        "magento/module-catalog-inventory": "*",
        "magento/module-configurable-product": "*",
        "magento/module-store": "*",
        "magento/module-sales-rule": "*",
        "magento/module-backend": "*",
        "angeo/module-openai-product-feed": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "angeo/module-aeo-audit": "Audit your full AEO + AI feed readiness.",
        "angeo/module-llms-txt": "Generate llms.txt for AI content map.",
        "angeo/module-mcp-server": "Expose read-only commerce tools over MCP."
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Angeo\\OpenAiProductFeedApi\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Angeo\\OpenAiProductFeedApi\\Test\\": "Test/"
        }
    }
}